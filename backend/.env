# Server Configuration
PROJECT_NAME="Expanse Collaboration API"
HOST="0.0.0.0"
PORT=8000
DEBUG=True

# Database Configuration
# Primary: PostgreSQL. Example local database setup:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/expanse
# Fallback / Quickstart Option (can use SQLite for local testing without server):
DATABASE_URL=sqlite:///./expanse.db

# Security & JWT Configuration
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=8cf2e7d7054fcfb2b73ebf1c32729a67448e91456d2ee61a6b0c2d3fbdf2db56
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (JSON list of allowed hosts)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# OpenAI Configurations
# Paste your OpenAI API Key here:
OPENAI_API_KEY=""

